<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/nav_graph"
  app:startDestination="@id/game_fragment">

  <fragment
    android:id="@+id/game_fragment"
    android:name="edu.cnm.deepdive.codebreaker.app.controller.GameFragment"
    android:label="@string/game_fragment_label"
    tools:layout="@layout/fragment_game">

    <action
      android:id="@+id/navigate_to_settings"
      app:destination="@id/settings_fragment"/>

  </fragment>

  <fragment
    android:id="@+id/settings_fragment"
    android:name="edu.cnm.deepdive.codebreaker.app.controller.SettingsFragment"
    android:label="@string/settings_fragment_label"
    tools:layout="@xml/preferences"/>

</navigation>