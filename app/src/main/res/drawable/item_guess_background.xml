<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:width="@dimen/base_drawable_size"
  android:height="@dimen/base_drawable_size"
  android:viewportWidth="@integer/base_viewport_size"
  android:viewportHeight="@integer/base_viewport_size">

  <item
    android:top="-1dp"
    android:left="-1dp"
    android:right="-1dp">

    <shape android:shape="rectangle">

      <stroke
        android:width="1dp"
        android:color="?attr/colorOutline"/>

      <solid android:color="@android:color/transparent"/>

    </shape>

  </item>

</layer-list>
