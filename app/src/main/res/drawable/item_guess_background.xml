<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:width="@dimen/base_drawable_size"
  android:height="@dimen/base_drawable_size"
  android:viewportWidth="24"
  android:viewportHeight="24">

  <item
    android:top="@dimen/outside_viewport_offset"
    android:end="@dimen/outside_viewport_offset"
    android:start="@dimen/outside_viewport_offset">

    <shape
      android:shape="rectangle">

      <stroke
        android:width="@dimen/guess_separator_width"
        android:color="?attr/colorOutline"/>

      <solid
        android:color="@android:color/transparent"/>

    </shape>

  </item>

</layer-list>