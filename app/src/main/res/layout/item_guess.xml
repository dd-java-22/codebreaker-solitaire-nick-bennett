<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/container"
  android:orientation="horizontal"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:paddingHorizontal="@dimen/half_dynamic_spacing"
  android:paddingVertical="@dimen/half_static_spacing"
  android:background="?attr/selectableItemBackground"
  android:baselineAligned="false"
  android:clickable="true"
  android:focusable="true"
  android:gravity="center_vertical">

  <TextView
    android:id="@+id/number"
    android:layout_width="@dimen/guess_number_width"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/half_dynamic_spacing"
    android:paddingEnd="@dimen/half_static_spacing"
    android:paddingVertical="0dp"
    android:includeFontPadding="false"
    android:textAlignment="viewEnd"
    style="?attr/textAppearanceTitleLarge"
    tools:text="10"/>

  <LinearLayout
    android:id="@+id/symbols"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:layout_margin="@dimen/half_static_spacing"
    android:orientation="horizontal"/>

  <LinearLayout
    android:id="@+id/results"
    android:layout_width="@dimen/guess_results_width"
    android:layout_height="wrap_content"
    android:background="@drawable/match_count_separator"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/full_dynamic_spacing"
    android:paddingVertical="@dimen/half_dynamic_spacing">

    <TextView
      android:id="@+id/exact_matches"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_gravity="top|start"
      android:includeFontPadding="false"
      android:textAlignment="viewStart"
      style="?attr/textAppearanceBodyLarge"
      tools:text="2"/>

    <TextView
      android:id="@+id/near_matches"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:layout_gravity="bottom|end"
      android:includeFontPadding="false"
      android:textAlignment="viewEnd"
      style="?attr/textAppearanceBodyLarge"
      tools:text="1"/>

  </LinearLayout>

</LinearLayout>