<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".controller.GameFragment">

  <androidx.recyclerview.widget.RecyclerView
    android:id="@+id/guesses"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:orientation="vertical"
    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toTopOf="@id/submit"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    tools:listitem="@android:layout/simple_list_item_1">
  </androidx.recyclerview.widget.RecyclerView>

  <RadioGroup
    android:id="@+id/guess_controls"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/half_dynamic_spacing"
    app:layout_constraintBottom_toTopOf="@id/palette"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toStartOf="@id/submit"/>

  <ImageButton
    android:id="@+id/submit"
    android:layout_width="@dimen/button_size"
    android:layout_height="@dimen/button_size"
    android:layout_margin="@dimen/half_dynamic_spacing"
    android:src="@drawable/send_button"
    android:scaleType="fitXY"
    android:background="?attr/selectableItemBackgroundBorderless"
    android:contentDescription="@string/submit_guess"
    android:tooltipText="@string/submit_guess"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintBottom_toTopOf="@id/palette"/>

  <LinearLayout
    android:id="@+id/palette"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center"
    android:padding="@dimen/half_dynamic_spacing"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>

  <com.google.android.material.progressindicator.CircularProgressIndicator
    android:id="@+id/loading"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:indeterminate="true"
    android:visibility="gone"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
